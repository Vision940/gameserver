#!/usr/bin/env bash

##
## Dynamically generated bash script with default completion method for nested case functions
## Case options that use this syntax are supported (any # of spaces is fine):
## case _$1_ in
##   _option_) : Short description
##     case _$1_$2_ in
##       _option_suboption_) : Capability here
##         :
##       ;;
##     esac
##   ;;
## esac
##
## The : <desc> part of the case option is used to generate descriptions in the completion opts
##
## Specific function handling can be added for a cmd with a specialized fxn included at render time
##
## Gets generated by called route - templates/<cmd>-completion
##
## Author: Daniel Tucker <github.com/Vision940>
##

_{{ game }}() {
  local completions

  # Command specific methods added here
  {% if game == "game" %}
  __gs_game_comp "$1" "$2" "$3" && return 0
  {% endif %}

  local completions=()
  if (( COMP_CWORD == 1 )); then
    # Get options (and descriptions if available)
    mapfile -t completions < <(declare -f {{ game }} | sed -ne '/^\s.*)$/,+1 { /)$/N;s/\s*_\(.*\)_)\(\n\s\+ : \(.*\);\)\{0,1\}.*/\1\t\3/p; }' | grep -v [*_] | sed -e 's/\t$//g')
  elif (( COMP_CWORD == 2 )); then
    # Get suboptions (and descriptions if available)
    mapfile -t completions < <(declare -f {{ game }} | sed -ne "\|^\s_.*$3_.*_)$|,+1 { /)$/N;s|\s*_$3"'_\(.*\)_)\(\n\s\+ : \(.*\);\)\{0,1\}.*|\1\t\3|p; }' | grep -v [*_] | sed -e 's/\t$//g')
  fi

  __gs_comp_resp "$2" "${completions[@]}"
}
complete -F _{{ game }} {{ game }}

{# Jinja thinks "{#" is a comment so need raw #}
{% raw %}
# Inspired by cobra completion used in tailscale
__gs_comp_resp() {
  local cur="$1"
  shift

  local tab=$'\t'
  local completions=("$@")
  COMPREPLY=()

  # If no tabs, just respond with words
  if [[ "${completions[*]}" != *$tab* ]]; then
    COMPREPLY=( $(compgen -W "${completions[*]}" -- "$cur") )
    return 0
  fi

  # Filter comp options from cur
  local comp desc longest=0 line
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    comp="${line%%$tab*}"

    [[ "$comp" == "$cur"* ]] || continue

    COMPREPLY+=("$line")

    if (( ${#comp} > longest )); then
      longest=${#comp}
    fi
  done < <(printf '%s\n' "${completions[@]}")

  # Either respond with last option or provide descriptions
  if (( ${#COMPREPLY[@]} == 1 )); then
    COMPREPLY[0]="${COMPREPLY[0]%%$tab*}"
  else
    __gs_fmt_comp_desc "$longest"
  fi
}
{% endraw %}


{% raw %}
__gs_fmt_comp_desc() {
  local tab=$'\t'
  local longest="$1"
  local comp desc maxdesclength i cidx

  # Try extra hard to get COLUMNS
  shopt -s checkwinsize
  (:) # this ensures LINES and COLUMNS are set
  [[ -z $COLUMNS ]] && COLUMNS=$(tput cols)

  for cidx in "${!COMPREPLY[@]}"; do
    comp="${COMPREPLY[$cidx]}"

    if [[ "$comp" == *$tab* ]]; then
      desc="${comp#*$tab}"
      comp="${comp%%$tab*}"

      maxdesclength=$(( COLUMNS - longest - 4 ))

      # Space out descriptions appropriately
      if (( maxdesclength > 8 )); then
        for (( i=${#comp}; i<longest; i++ )); do
          comp+=" "
        done
      else
        maxdesclength=$(( COLUMNS - ${#comp} - 4 ))
      fi

      # Build description strings
      if (( maxdesclength > 0 )) && [[ -n "$desc" ]]; then
        if (( ${#desc} > maxdesclength )); then
          desc="${desc:0:$((maxdesclength - 1))}…"
        fi
        comp+="  ($desc)"
      fi

      COMPREPLY[$cidx]="$comp"
    fi
  done
}
{% endraw %}

# Responds with available games when completing load option
__gs_game_comp() {
  {% raw %}
  if (( ${#COMP_WORDS[@]} == 3 )) && [[ "$3" == "load" ]]; then
  {% endraw %}
    COMPREPLY=($(compgen -W "{{ game_list }}" -- ${2}))
    return 0
  fi
  return 1
}

